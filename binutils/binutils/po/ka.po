#, c-format
msgid "      --recurse-limit    Enable a demangling recursion limit.  (default)\n"
msgstr ""

#: nm.c:317
#, c-format
msgid "      --no-recurse-limit Disable a demangling recursion limit.\n"
msgstr ""

#: nm.c:319
#, c-format
