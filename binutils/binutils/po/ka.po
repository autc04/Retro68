msgstr ""

#: nm.c:321
#, c-format
msgid "  -e                     (ignored)\n"
msgstr ""

#: nm.c:323
#, c-format
msgid ""
"  -f, --format=FORMAT    Use the output format FORMAT.  FORMAT can be `bsd',\n"
